import { defineExecutor } from "@patchdock/sdk";

export default defineExecutor({
  async run(ctx, input) {
    ctx.log(`Executing ${input.plan.steps.length} planned step(s).`);

    return {
      status: "success",
      step_results: input.plan.steps.map((step) => ({
        step_id: step.id,
        status: "success",
        notes: "Default scaffold executor did not modify files.",
      })),
    };
  },
});
